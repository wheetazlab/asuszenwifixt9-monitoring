# Template — do NOT commit actual credentials.
# Copy to secret.yml, fill in the real values, apply once, then delete.
#
#   kubectl apply -f k8s/secret.yml
#
# Keys must match the env var names the app expects (SSH_USERNAME, SSH_PASSWORD)
# so they are loaded correctly via envFrom: secretRef.
apiVersion: v1
kind: Secret
metadata:
  name: router-ssh-credentials
  namespace: asus-monitoring
type: Opaque
stringData:
  SSH_USERNAME: router
  SSH_PASSWORD: CHANGE_ME
